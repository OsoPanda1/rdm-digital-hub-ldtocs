#!/bin/sh
#
# RDM Digital Hub — Git Guardian pre-commit hook (evolucionado)
# - Detecta secretos, credenciales y patrones sensibles antes de hacer commit.
# - Usa gitleaks como motor de escaneo (local o Docker).
# - Bloquea commits con .env y llaves privadas por defecto.
#
# Instalación recomendada:
#   git config core.hooksPath .githooks
#
# Variables de entorno útiles:
#   GITLEAKS_PATH        → ruta específica al binario gitleaks (opcional)
#   GITLEAKS_CONFIG      → ruta a .gitleaks.toml custom (opcional)
#   GITLEAKS_DOCKER_IMG  → imagen Docker para gitleaks (por defecto ghcr.io/gitleaks/gitleaks:latest)
#

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ----------------------------------------
# 0. Skips y contexto
# ----------------------------------------

# Permitir saltar el hook (por ejemplo en scripts controlados)
if [ "$RDM_GIT_GUARDIAN_SKIP" = "1" ]; then
  echo "${YELLOW}⚠ Git Guardian: hook skipped via RDM_GIT_GUARDIAN_SKIP=1.${NC}"
  exit 0
fi

# No escanear merges vacíos
if git rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
  echo "${YELLOW}⚠ Merge commit detected — Git Guardian skipping.${NC}"
  exit 0
fi

# ----------------------------------------
# 1. Resolver binario de gitleaks
# ----------------------------------------

GITLEAKS_BIN=""
GITLEAKS_CONFIG="${GITLEAKS_CONFIG:-}"
GITLEAKS_DOCKER_IMG="${GITLEAKS_DOCKER_IMG:-ghcr.io/gitleaks/gitleaks:latest}"

if [ -n "$GITLEAKS_PATH" ] && [ -x "$GITLEAKS_PATH" ]; then
  GITLEAKS_BIN="$GITLEAKS_PATH"
elif command -v gitleaks >/dev/null 2>&1; then
  GITLEAKS_BIN="gitleaks"
elif command -v docker >/dev/null 2>&1; then
  echo "${YELLOW}⚠ gitleaks not found locally; using Docker image ${GITLEAKS_DOCKER_IMG}.${NC}"
  GITLEAKS_BIN="docker run --rm -v \"${PWD}:/src\" -w /src ${GITLEAKS_DOCKER_IMG}"
else
  echo "${YELLOW}⚠ gitleaks not installed, and Docker not available.${NC}"
  echo "${YELLOW}⚠ Commit will proceed WITHOUT secret scanning. Install gitleaks ASAP.${NC}"
  echo "${YELLOW}   brew install gitleaks  # macOS${NC}"
  echo "${YELLOW}   or see https://github.com/gitleaks/gitleaks/releases${NC}"
  exit 0
fi

# ----------------------------------------
# 2. Obtener archivos staged
# ----------------------------------------

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "${GREEN}✓ Git Guardian: no staged files to scan.${NC}"
  exit 0
fi

echo "${GREEN}🔍 Git Guardian: scanning staged changes for secrets...${NC}"

# ----------------------------------------
# 3. Ejecutar gitleaks en protect-mode sobre staged
# ----------------------------------------

GITLEAKS_CMD="$GITLEAKS_BIN protect --staged --source=\"$PWD\" --no-banner"
if [ -n "$GITLEAKS_CONFIG" ]; then
  GITLEAKS_CMD="$GITLEAKS_CMD -c \"$GITLEAKS_CONFIG\""
fi

# Ejecutar y capturar salida y exit code
GITLEAKS_OUTPUT=$(
  # shellcheck disable=SC2086
  sh -c "$GITLEAKS_CMD" 2>&1
)
GITLEAKS_EXIT_CODE=$?

if [ $GITLEAKS_EXIT_CODE -ne 0 ]; then
  echo "${RED}❌ Git Guardian BLOCKED: gitleaks detected potential secrets!${NC}"
  echo "${RED}   Exit code: ${GITLEAKS_EXIT_CODE}${NC}"
  echo "${YELLOW}--- gitleaks output ---${NC}"
  echo "$GITLEAKS_OUTPUT"
  echo "${YELLOW}-----------------------${NC}"
  echo "${RED}   Run 'gitleaks protect --staged' locally para analizar en detalle.${NC}"
  echo "${RED}   Si identificas falsos positivos, ajusta .gitleaks.toml (allowlist/patterns).${NC}"
  exit 1
fi

# ----------------------------------------
# 4. Bloquear .env en commits
# ----------------------------------------

ENV_IN_STAGED=$(echo "$STAGED_FILES" | grep -E '\.env$|\.env\.local$|\.env\.production$|\.env\.development$' || true)

if [ -n "$ENV_IN_STAGED" ]; then
  echo "${RED}❌ Git Guardian BLOCKED: .env files detected in commit:${NC}"
  echo "$ENV_IN_STAGED" | sed 's/^/   /'
  echo "${YELLOW}   Acción recomendada:${NC}"
  echo "${YELLOW}   - Mueve tus variables a un vault (1Password, Doppler, Vault, etc.).${NC}"
  echo "${YELLOW}   - Añade las rutas .env a .gitignore si son locales.${NC}"
  exit 1
fi

# ----------------------------------------
# 5. Bloquear llaves privadas en commits
# ----------------------------------------

PRIVKEY_IN_STAGED=$(echo "$STAGED_FILES" | grep -E '\.pem$|\.key$|\.p12$|\.pfx$|id_rsa$|id_ed25519$' || true)

if [ -n "$PRIVKEY_IN_STAGED" ]; then
  echo "${RED}❌ Git Guardian BLOCKED: Private key files detected in commit:${NC}"
  echo "$PRIVKEY_IN_STAGED" | sed 's/^/   /'
  echo "${YELLOW}   Acción recomendada:${NC}"
  echo "${YELLOW}   - Elimina las llaves del repo y rota las credenciales inmediatamente.${NC}"
  echo "${YELLOW}   - Usa ssh-agent / secrets manager para distribuir llaves.${NC}"
  exit 1
fi

# ----------------------------------------
# 6. Éxito
# ----------------------------------------

echo "${GREEN}✓ Git Guardian: scan passed — no secrets detected in staged changes.${NC}"
exit 0
