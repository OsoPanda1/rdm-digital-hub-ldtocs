#!/bin/sh
#
# RDM Digital Hub — Git Guardian pre-commit hook
# Detects secrets, credentials, and sensitive patterns before commits.
# Uses gitleaks as the scanning engine.
#
# Install: git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# --- 1. Verify gitleaks is available ---
if ! command -v gitleaks >/dev/null 2>&1; then
  if command -v docker >/dev/null 2>&1; then
    echo "${YELLOW}⚠ gitleaks not found locally; will attempt Docker scan.${NC}"
    GITLEAKS="docker run --rm -v \"${PWD}:/src\" -w /src ghcr.io/gitleaks/gitleaks:latest"
  else
    echo "${YELLOW}⚠ gitleaks not installed. Install: brew install gitleaks or download from https://github.com/gitleaks/gitleaks/releases${NC}"
    echo "${YELLOW}⚠ Commit will proceed without secret scanning.${NC}"
    exit 0
  fi
else
  GITLEAKS="gitleaks"
fi

# --- 2. Scan staged changes (git diff --cached) ---
echo "${GREEN}🔍 Git Guardian: scanning staged changes for secrets...${NC}"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "${GREEN}✓ No staged files to scan.${NC}"
  exit 0
fi

# Create a temporary patch of staged changes for gitleaks to analyze
git diff --cached --diff-filter=ACM > /tmp/gitleaks-staged.patch 2>/dev/null || true

# Run gitleaks protect mode on the staged patch
GITLEAKS_OUTPUT=$(eval "$GITLEAKS protect --staged --source=\"$PWD\" 2>&1") || true

if echo "$GITLEAKS_OUTPUT" | grep -qi "leak\|secret\|found"; then
  # Check if leaks were actually found (gitleaks exits non-zero)
  if ! eval "$GITLEAKS protect --staged --source=\"$PWD\" --no-banner" > /dev/null 2>&1; then
    echo "${RED}❌ Git Guardian BLOCKED: Secrets detected in staged changes!${NC}"
    echo "${RED}   Run 'gitleaks protect --staged' locally to identify the issue.${NC}"
    echo "${RED}   If false positive, add to .gitleaks.toml allowlist.${NC}"
    exit 1
  fi
fi

# --- 3. Check for .env files being committed ---
ENV_IN_STAGED=$(git diff --cached --name-only | grep -E '\.env$|\.env\.local$|\.env\.production$|\.env\.development$' || true)
if [ -n "$ENV_IN_STAGED" ]; then
  echo "${RED}❌ Git Guardian BLOCKED: .env files detected in commit:${NC}"
  echo "$ENV_IN_STAGED" | sed 's/^/   /'
  echo "${YELLOW}   Remove .env files from staging or add to .gitignore before committing.${NC}"
  exit 1
fi

# --- 4. Check for private keys ---
PRIVKEY_IN_STAGED=$(git diff --cached --name-only | grep -E '\.pem$|\.key$|\.p12$|\.pfx$|id_rsa$|id_ed25519$' || true)
if [ -n "$PRIVKEY_IN_STAGED" ]; then
  echo "${RED}❌ Git Guardian BLOCKED: Private key files detected in commit:${NC}"
  echo "$PRIVKEY_IN_STAGED" | sed 's/^/   /'
  exit 1
fi

echo "${GREEN}✓ Git Guardian: scan passed — no secrets detected.${NC}"
exit 0
