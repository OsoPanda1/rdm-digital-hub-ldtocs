generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// GEMELOS DIGITALES · TELEMETRÍA & OBSERVABILIDAD
// =====================================================

model DigitalTwin {
  id          String     @id @default(cuid())
  modelType   TwinType
  modelId     String?
  sourceId    String
  status      TwinStatus @default(ACTIVE)

  /// Telemetría cruda (sensores, eventos, latencias, métricas de salud)
  telemetry   Json       @default("{}")
  /// Propiedades “lentas”: configuración, capacidades declaradas, límites
  properties  Json       @default("{}")
  /// Metadata extendida: etiquetas, versión de modelo, checksums, etc.
  metadata    Json       @default("{}")

  /// Huella para futuros esquemas híbridos pre/post‑cuántum (ej. hash en MSR)
  quantumFingerprint String? @db.VarChar(255)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([sourceId, modelType])
  @@index([modelType, status])
  @@index([status, updatedAt])
}

enum TwinType {
  PLACE_TWIN
  MERCHANT_TWIN
  ROUTE_TWIN
  AGENT_TWIN
}

enum TwinStatus {
  ACTIVE
  INACTIVE
  SIMULATING
  MAINTENANCE
}

// =====================================================
// ENTIDADES TURÍSTICAS
// =====================================================

model Place {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String    @db.Text
  type        String
  latitude    Float
  longitude   Float
  altitude    Float?
  city        String    @default("Real del Monte")
  state       String    @default("Hidalgo")
  country     String    @default("México")
  metadata    Json      @default("{}")
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([city])
  @@index([state])
  @@index([latitude, longitude])
  @@index([type, isFeatured])
}

model Merchant {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  category        String
  immersionLevel  Int      @default(1)
  description     String   @db.Text
  priceRange      String
  address         String
  latitude        Float?
  longitude       Float?
  city            String   @default("Real del Monte")
  state           String   @default("Hidalgo")
  country         String   @default("México")
  phone           String?
  website         String?
  mainImage       String?
  tags            String[]
  pciCompliance   Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category, isActive])
  @@index([city])
  @@index([latitude, longitude])
}

model Route {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  theme        String
  difficulty   String      @default("EASY")
  fitnessScore Float       @default(0.0)
  stops        RouteStop[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model RouteStop {
  id      String @id @default(cuid())
  order   Int
  placeId String
  routeId String

  route   Route  @relation(fields: [routeId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  startDate   DateTime
  endDate     DateTime
  location    String
  image       String?
}

model Legend {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String
  content     String   @db.Text
  tags        String[]
}

model Saying {
  id          String   @id @default(cuid())
  phrase      String
  meaning     String   @db.Text
  origin      String?
}

// =====================================================
// USUARIOS Y COMERCIO
// =====================================================

enum Role {
  VISITOR
  MERCHANT
  ADMIN
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String?
  role         Role          @default(VISITOR)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  donations    Donation[]
  interactions Interaction[]
  aiLogs       AiInteractionLog[]
}

model Donation {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  amount     Int
  currency   String   @default("mxn")
  provider   String   @default("stripe")
  providerId String

  /// requestId que generas en la ruta /donations (para trazabilidad completa)
  requestId  String?  @db.VarChar(100)

  /// Hash o ID externo (p.ej. ancla en MSR Blockchain / Evidence Chain)
  ledgerAnchor String? @db.VarChar(255)

  /// Metadatos para telemetría / observabilidad (IP, UA, tags, etc.)
  telemetry  Json     @default("{}")

  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([provider, providerId])
  @@index([userId, createdAt])
}

model Interaction {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  kind       String
  businessId String?
  context    String?
  createdAt  DateTime @default(now())

  @@index([userId, kind, createdAt])
}

// =====================================================
// IA / REALITO · TELEMETRÍA COGNITIVA
// =====================================================

model AiInteractionLog {
  id          String   @id @default(cuid())
  userId      String
  channel     String         // web, whatsapp, kiosk, etc.
  sourceModel String         // modelo de IA
  prompt      String   @db.Text
  response    String   @db.Text
  latencyMs   Int
  createdAt   DateTime @default(now())

  /// IP, UA, geolocalización aproximada, flags de moderación, etc.
  metadata    Json     @default("{}")

  /// Perfil de seguridad criptográfica de la sesión (pre/híbrido/post‑Q)
  cryptoProfile String? @db.VarChar(50)

  @@index([createdAt])
  @@index([userId, channel])
}

// =====================================================
// YUN BE · JOURNALING & RECUPERACIÓN
// =====================================================

model YunBeEvent {
  id              String   @id @default(cuid())
  eventType       String
  payload         Json     @default("{}")
  status          JournalStatus @default(PENDING)
  idempotencyKey  String   @unique
  supabaseUserId  String?
  source          String   @default("system")
  federationId    String?
  ethicsScore     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([idempotencyKey])
  @@index([eventType, status])
}

model YunBeJournal {
  id              String   @id @default(cuid())
  operationType   String
  entityType      String
  entityId        String?
  payload         Json     @default("{}")
  status          JournalStatus @default(PENDING)
  idempotencyKey  String   @unique
  supabaseUserId  String?
  stripeId        String?
  metadata        Json     @default("{}")
  retryCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([idempotencyKey])
  @@index([operationType, status])
}

model YunBeRecoveryReport {
  id                 String   @id @default(cuid())
  startedAt          DateTime @default(now())
  endedAt            DateTime?
  operationsReplayed Int      @default(0)
  incidentsCount     Int      @default(0)
  details            Json     @default("{}")
  environment        String   @default("unknown")
  createdAt          DateTime @default(now())
}

model YunBeSlackNotification {
  id              String   @id @default(cuid())
  channel         String   @default("#kernel-alerts")
  eventType       String
  message         String   @db.Text
  incidentLevel   String   @default("info")
  delivered       Boolean  @default(false)
  createdAt       DateTime @default(now())
}

enum JournalStatus {
  PENDING
  COMPLETED
  FAILED
  RECONCILED
}

// =====================================================
// GAMIFICATION KERNEL · GUARDIANES & MISIONES
// =====================================================

model GamificationPlayer {
  id              Int      @id @default(autoincrement())
  supabaseUserId  String   @unique
  displayName     String   @default("")
  avatarId        Int?
  level           Int      @default(1)
  xp              Int      @default(0)
  virtuePoints    Int      @default(0)
  reputationScore Int      @default(2000)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  avatar          GamificationGuardian?  @relation(fields: [avatarId], references: [id])
  questLogs       GamificationQuestLog[]
  rewards         GamificationReward[]
  emotionStates   EmotionState[]
  cattleyaLinks   GamificationCattleyaLink[]
}

model GamificationGuardian {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  description   String   @db.Text
  archetype     String   @default("observador")
  primaryVirtue String   @default("calma")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  players       GamificationPlayer[]
}

model EmotionState {
  id             Int      @id @default(autoincrement())
  playerId       Int
  label          String   @default("tranquilo")
  primaryEmotion String   @default("calm")
  intensity      Float    @default(0.5)
  source         String   @default("auto")
  createdAt      DateTime @default(now())

  player         GamificationPlayer @relation(fields: [playerId], references: [id])
}

model GamificationMission {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  title          String
  description    String   @db.Text
  context        String   @default("turismo")
  xpReward       Int      @default(100)
  virtueReward   Int      @default(10)
  maxCompletions Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  questLogs      GamificationQuestLog[]
}

model GamificationQuestLog {
  id          Int              @id @default(autoincrement())
  playerId    Int
  missionId   Int
  status      QuestStatus      @default(PENDING)
  progress    Float            @default(0)
  completions Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  player      GamificationPlayer  @relation(fields: [playerId], references: [id])
  mission     GamificationMission @relation(fields: [missionId], references: [id])

  @@unique([playerId, missionId])
}

enum QuestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

model GamificationReward {
  id          Int        @id @default(autoincrement())
  playerId    Int
  rewardCode  String
  type        RewardType @default(BADGE)
  metadata    Json       @default("{}")
  claimedAt   DateTime   @default(now())

  player      GamificationPlayer @relation(fields: [playerId], references: [id])
}

enum RewardType {
  BADGE
  SKIN
  XR_ACCESS
  CATTLEYA_BENEFIT
}

model GamificationCattleyaLink {
  id             Int      @id @default(autoincrement())
  playerId       Int
  cattleyaUserId Int
  tier           String   @default("BASE")
  discountRate   Float    @default(0)
  cashbackRate   Float    @default(0)
  xpMultiplier   Float    @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  player         GamificationPlayer @relation(fields: [playerId], references: [id])

  @@unique([playerId, cattleyaUserId])
}

model CattleyaReputationEvent {
  id             Int      @id @default(autoincrement())
  playerId       Int
  eventType      String
  scoreDelta     Int
  reason         String   @db.Text
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  player         GamificationPlayer @relation(fields: [playerId], references: [id])

  @@index([playerId, createdAt])
  @@index([eventType, createdAt])
}

// =====================================================
// DATA GATEWAY · AUDIT LOGS & CACHE
// =====================================================

model DgAuditLog {
  id               String   @id @default(cuid())
  userId           String?
  serviceId        String?
  endpoint         String
  method           String
  params           Json     @default("{}")
  statusCode       Int
  durationMs       Int
  sourceIp         String?
  sensitivityLevel String   @default("low")
  federationId     String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([endpoint, createdAt])
}

model DgCacheEntry {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  value     Json
  ttl       Int      @default(300)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// =====================================================
// ARCHIVO SONORO DIGITAL · MÚSICA
// =====================================================

model MusicTrack {
  id          String   @id @default(uuid())
  title       String
  artist      String
  description String?

  coverUrl    String
  audioUrl    String

  active      Boolean  @default(true)

  // Para métricas de uso por pista
  playCount   Int      @default(0)
  lastPlayedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, createdAt])
  @@index([artist, active])
}

// =====================================================
// AUDIO GATEWAY · SPEECH-TO-TEXT / TEXT-TO-SPEECH
// =====================================================

model HeritageAudioSession {
  id                String   @id @default(cuid())
  supabaseUserId    String?
  heritageSiteId    String
  audioType         AudioType @default(NARRATION)
  
  /// Duración en milisegundos
  durationMs        Int?
  
  /// Versión del modelo AI Gateway usado
  gatewayModelVersion String?
  
  metadata          Json     @default("{}")
  
  // Relaciones
  transcriptions    AudioTranscription[]
  audioFiles        AudioFile[]
  gatewayLogs       AiGatewayLog[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([heritageSiteId, createdAt])
  @@index([audioType, createdAt])
  @@index([supabaseUserId, createdAt])
}

enum AudioType {
  NARRATION           // Pre-generated heritage site narrations
  USER_RECORDING      // User-uploaded voice recordings
  TOUR_GUIDE          // Automated tour guide audio
  ACCESSIBILITY       // Audio descriptions for accessibility
}

model AudioTranscription {
  id                String   @id @default(cuid())
  sessionId         String
  session           HeritageAudioSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  /// Texto transcrito del audio
  textContent       String   @db.Text
  
  /// Confianza del modelo (0-1)
  confidenceScore   Float    @default(0.95)
  
  /// Idioma detectado (ej: 'es', 'en', 'fr')
  detectedLanguage  String   @default("es")
  
  /// Tokens utilizados en transcripción
  tokensUsed        Int?
  
  /// Latencia en ms del API
  latencyMs         Int?
  
  metadata          Json     @default("{}")
  
  createdAt         DateTime @default(now())
  
  @@index([sessionId, createdAt])
  @@index([detectedLanguage])
}

model AudioFile {
  id                String   @id @default(cuid())
  sessionId         String
  session           HeritageAudioSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  /// Ruta en Supabase Storage (ej: "heritage/site_001/narration_abc123.mp3")
  supabasePath      String   @unique
  
  /// Tipo de archivo ('mp3', 'wav', 'm4a', etc.)
  fileType          String   @default("mp3")
  
  /// Tamaño en bytes
  sizeBytes         Int
  
  /// URL pública para descargar (si aplica)
  publicUrl         String?
  
  /// Duración estimada en segundos (si está disponible)
  durationSeconds   Int?
  
  /// Checksum MD5 para deduplicación
  checksumMd5       String?
  
  metadata          Json     @default("{}")
  
  createdAt         DateTime @default(now())
  expiresAt         DateTime? // Para manejo de retención
  
  @@index([sessionId, createdAt])
  @@index([supabasePath])
}

model AiGatewayLog {
  id                String   @id @default(cuid())
  sessionId         String
  session           HeritageAudioSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  supabaseUserId    String?
  
  /// Tipo de operación ('speech_generation', 'transcription')
  operationType     String   @default("speech_generation")
  
  /// Modelo usado ('openai/tts-1', 'openai/whisper-1')
  model              String
  
  /// Tokens de entrada
  inputTokens       Int?
  
  /// Tokens de salida
  outputTokens      Int?
  
  /// Latencia en ms
  latencyMs         Int
  
  /// Estado ('success', 'error', 'timeout')
  status            String   @default("success")
  
  /// Mensaje de error si aplica
  errorMessage      String?
  
  /// Código de error de AI Gateway
  errorCode         String?
  
  /// Datos de auditoría (IP, user-agent, región)
  auditData         Json     @default("{}")
  
  metadata          Json     @default("{}")
  
  createdAt         DateTime @default(now())
  
  @@index([operationType, status, createdAt])
  @@index([supabaseUserId, createdAt])
  @@index([status, createdAt])
  @@index([model, createdAt])
}

model HeritageAudioNarration {
  id                String   @id @default(cuid())
  
  /// Slug único para la narración (ej: 'real-del-monte-historic-town')
  slug              String   @unique
  
  /// Sitio patrimonial
  siteName          String
  siteDescription   String?
  
  /// Texto a ser convertido a voz
  narrationText     String   @db.Text
  
  /// Idioma original de la narración
  language          String   @default("es")
  
  /// Voz seleccionada ('alloy', 'echo', 'fable', 'onyx', 'nova', 'shimmer')
  voiceId           String   @default("nova")
  
  /// Último session_id que generó este narración
  lastGeneratedSessionId String?
  
  /// URLs de archivos de audio por calidad/idioma
  audioVersions     Json     @default("{}") // { "es_normal": "url", "es_hq": "url" }
  
  /// Contar reproducciones
  playCount         Int      @default(0)
  
  /// Active/Inactive para distribución
  isActive          Boolean  @default(true)
  
  metadata          Json     @default("{}")
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([slug])
  @@index([isActive, createdAt])
  @@index([language])
}

model AudioUsageMetrics {
  id                String   @id @default(cuid())
  
  /// Referencia al usuario
  supabaseUserId    String?
  
  /// Tipo de operación
  operationType     String   @default("transcription")
  
  /// Contador de tokens usados
  tokensUsed        Int      @default(0)
  
  /// Costo estimado en USD
  estimatedCostUsd  Float    @default(0.0)
  
  /// Período de agregación (YYYY-MM)
  billingPeriod     String
  
  metadata          Json     @default("{}")
  
  createdAt         DateTime @default(now())
  
  @@unique([supabaseUserId, operationType, billingPeriod])
  @@index([billingPeriod, createdAt])
}
