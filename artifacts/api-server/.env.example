# RDM Digital Hub — API Server Environment Variables
# Copy this to .env and fill in the values

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@helium/heliumdb?sslmode=disable

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── TAMV 92.5 FM Radio (AzuraCast) ──────────────────────────
# Fill these after deploying AzuraCast to your server.
# See: docs/radio/azuracast-deployment.md
AZURACAST_URL=http://YOUR_AZURACAST_IP:8000
AZURACAST_API_KEY=your-azuracast-api-key
AZURACAST_STATION=tamv925

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-replit-url.replit.dev
