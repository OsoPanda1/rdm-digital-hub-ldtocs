# RDM Digital Hub — API Server Environment Variables
# Copy this to .env and fill in the values

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@helium/heliumdb?sslmode=disable

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── TAMV 92.5 FM Radio (AzuraCast on Oracle Cloud) ─────────
# Deploy AzuraCast to Oracle Cloud Always Free Tier ($0/mes).
# Guide: docs/radio/azuracast-deployment.md
# After deploying, fill these in Replit Secrets:
AZURACAST_URL=http://YOUR_ORACLE_PUBLIC_IP
AZURACAST_API_KEY=your-azuracast-api-key-here
AZURACAST_STATION=tamv925

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-replit-url.replit.dev
